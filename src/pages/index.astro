---
import AppSidebar from '../components/AppSidebar.astro';
import MonitorDialogs from '../components/MonitorDialogs.astro';
import MonitorWorkspace from '../components/MonitorWorkspace.astro';
import '../styles/pulsewatch.css';

const title = 'Status Checker - Monitor de estado de APIs';
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="Monitoriza el estado de tus APIs mediante WebSocket." />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=DM+Mono:wght@400;500&family=Manrope:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  </head>
  <body>
    <div class="pulsewatch-app">
      <AppSidebar />
      <MonitorWorkspace />
      <MonitorDialogs />
    </div>
    <script>
      import '../scripts/monitor.ts';
    </script>
  </body>
</html>
